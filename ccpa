    <script>
        $('.more').click(function () {
            $(this).addClass("open");
        });

        $(function () {
            var frm = $("#ccpa-form");
            frm.on("submit", function () {
                frm.addClass("working");

                $.post(frm.attr("action"), frm.serialize()).done(function (dat) {
                    if (!dat.ok) {
                        console.log(dat);
                        console.log("Error: " + dat.error);
                        return;
                    }
                    frm.hide();
                    $("#thanks").show();

                }).fail(function (e, x) {
                    console.log(e);
                    console.log("Error:" + e.toString());
                }).always(function () {
                    frm.removeClass("working");
                });
            });

        });
    </script>

