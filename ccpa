        //will loop through a div's children
        //uses class .active for current slide
        function slideShow(parentDiv, delay, noLoop) {
            var msgs = $(parentDiv);
            if (!msgs.find(".active").length) { //none are active
                msgs.children().first().addClass("active");
            }
            var ended;
            var nextSlide = function() {
                timeout(function() {
                    var cur = msgs.children(".active");
                    var next = cur.next();
                    if (!next.length) {
                        if (noLoop) {
                            ended = true;
                            return;
                        }
                        next = msgs.children().first();
                    }
                    // console.log("slideShow:index="+next.index());
                    cur.fadeOut('fast', function() {
                        msgs.find(".active").removeClass("active");
                        next.fadeIn('fast', function() {
                            $(this).addClass("active");
                        })
                    })
                }, delay).then(function() {
                    if (ended) {
                        return;
                    }
                    nextSlide();
                });
            }
            nextSlide();
        }

