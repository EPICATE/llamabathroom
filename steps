    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const next = document.getElementById("next");
            const step1 = document.getElementById("step1");

            // Hide Next button if Step 1 is active
            if (step1.classList.contains("active")) {
                next.style.display = "none";
            }
        });

        function setSelection(id, value) {
            // Set selected value in hidden input
            document.getElementById('service_type').value = value;

            document.getElementById("bathroom-type-error").classList.add("hidden");
            // Remove the selected class from all options
            document.querySelectorAll('.option').forEach(option => {
                option.classList.remove('selected');
            });

            // Highlight the selected option
            let selectedOption = document.getElementById('option' + id);
            if (selectedOption) {
                selectedOption.classList.add('selected');
            }

            // Move to next step
            // document.getElementById('step1').classList.add('hidden');
            document.getElementById('next').click();
        }

        function handleHomeownerSelection(event) {
            document.getElementById('residence_ownership').value = event.target.value;
        }
    </script>

    <script>
        let TIME_SPENT = 0;
        let setIntervalInstance;

        // Start the timer
        function startTimer() {
            setIntervalInstance = setInterval(() => {
                TIME_SPENT += 1;
            }, 1000);
        }

        // Start the timer if on steps page
        window.onload = function() {
            startTimer();
        };
    </script>

